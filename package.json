{
  "name": "copy-paste-everywhere",
  "version": "1.0.7",
  "description": "Private real-time clipboard sync across all devices — text, images, videos, files, and drag & drop.",
  "keywords": [
    "clipboard",
    "sync",
    "realtime",
    "nextjs",
    "socket.io",
    "drag-and-drop",
    "file paste",
    "image paste",
    "video paste",
    "video support",
    "download",
    "upload",
    "cross-platform",
    "open-source"
  ],
  "author": "asepindrak",
  "repository": {
    "type": "git",
    "url": "https://github.com/asepindrak/copy-paste-everywhere"
  },
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development TS_NODE_COMPILER_OPTIONS=\"{\\\"module\\\":\\\"commonjs\\\"}\" ts-node server.ts",
    "build": "next build && tsc server.ts --outDir dist --module commonjs --esModuleInterop --skipLibCheck",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.482.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pg": "^8.20.0",
    "@types/pg-connection-string": "^0.1.1",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "pg-connection-string": "^2.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-select": "^5.10.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/next-auth": "^3.13.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
